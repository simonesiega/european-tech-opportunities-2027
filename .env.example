# Copy this file to .env. The CLI loads .env automatically; process environment
# values override it. Never commit .env.

# SQLite is the canonical data store.
OPPORTUNITIES_DATABASE_URL=sqlite:///data/opportunities.db
OPPORTUNITIES_README_PATH=README.md
OPPORTUNITIES_SEARCH_CONFIG_DIR=configs/searches
OPPORTUNITIES_CATEGORY_CONFIG_PATH=configs/categories.yml
OPPORTUNITIES_TARGET_CYCLE=2027

# Optional global search limits. Leave unset to use each search YAML value.
# LinkedIn currently tends to repeat/stop near 100 unique guest-search results.
# OPPORTUNITIES_SEARCH_MAX_PAGES=4
# OPPORTUNITIES_SEARCH_MAX_RESULTS=100
# OPPORTUNITIES_SEARCH_MAX_RECHECKS=25

# Conservative HTTP controls.
OPPORTUNITIES_RATE_LIMIT_SECONDS=2.0
OPPORTUNITIES_MAX_CONCURRENCY=3
OPPORTUNITIES_REQUEST_TIMEOUT_SECONDS=20
OPPORTUNITIES_CONNECT_TIMEOUT_SECONDS=10
OPPORTUNITIES_MAX_RETRIES=3
OPPORTUNITIES_RETRY_BACKOFF_SECONDS=0.5
OPPORTUNITIES_MAX_RESPONSE_BYTES=15000000

# A job closes only after this many explicit 404/410 detail confirmations for
# every search that previously observed it. Search-page absence never closes it.
OPPORTUNITIES_CLOSURE_CONFIRMATION_RUNS=2

# This switch does not grant permission. Set true only after LinkedIn grants
# express authorization for automated collection.
OPPORTUNITIES_LINKEDIN_CRAWL_AUTHORIZED=false
OPPORTUNITIES_USER_AGENT=european-tech-opportunities-2027/0.1 (+https://github.com/simonesiega/european-tech-opportunities-2027)
OPPORTUNITIES_LOG_LEVEL=INFO

# Optional advanced YAML settings file. Process environment remains highest priority.
# OPPORTUNITIES_SETTINGS_FILE=configs/settings.yml

# Website and VPS deployment. The container uses /app/data/opportunities.db internally.
SITE_URL=https://opportunities2027.simonesiega.com
