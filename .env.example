# Copy this file to .env. The CLI loads .env automatically; process environment
# values override it. Never commit .env.

# SQLite is the canonical data store.
INTERNSHIPS_DATABASE_URL=sqlite:///data/internships.db
INTERNSHIPS_README_PATH=README.md
INTERNSHIPS_SEARCH_CONFIG_DIR=configs/searches
INTERNSHIPS_CATEGORY_CONFIG_PATH=configs/categories.yml
INTERNSHIPS_TARGET_CYCLE=2027

# Optional global search limits. Leave blank to use each search YAML value.
# LinkedIn currently tends to repeat/stop near 100 unique guest-search results.
# INTERNSHIPS_SEARCH_MAX_PAGES=4
# INTERNSHIPS_SEARCH_MAX_RESULTS=100
# INTERNSHIPS_SEARCH_MAX_RECHECKS=25

# Conservative HTTP controls.
INTERNSHIPS_RATE_LIMIT_SECONDS=2.0
INTERNSHIPS_MAX_CONCURRENCY=3
INTERNSHIPS_REQUEST_TIMEOUT_SECONDS=20
INTERNSHIPS_CONNECT_TIMEOUT_SECONDS=10
INTERNSHIPS_MAX_RETRIES=3
INTERNSHIPS_RETRY_BACKOFF_SECONDS=0.5
INTERNSHIPS_MAX_RESPONSE_BYTES=15000000

# A job closes only after this many explicit 404/410 detail confirmations for
# every search that previously observed it. Search-page absence never closes it.
INTERNSHIPS_CLOSURE_CONFIRMATION_RUNS=2

# This switch does not grant permission. Set true only after LinkedIn grants
# express authorization for automated collection.
INTERNSHIPS_LINKEDIN_CRAWL_AUTHORIZED=false
INTERNSHIPS_USER_AGENT=european-tech-internships-2027/0.1 (+https://github.com/simonesiega/european-tech-internships-2027)
INTERNSHIPS_LOG_LEVEL=INFO

# Optional advanced YAML settings file. Process environment remains highest priority.
# INTERNSHIPS_SETTINGS_FILE=configs/settings.yml

# Website and VPS deployment. The container uses /app/data/internships.db internally.
SITE_URL=https://internship2027.simonesiega.com
