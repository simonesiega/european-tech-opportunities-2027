{
  "name": "european-tech-opportunities-2027-site",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.14",
  "engines": {
    "node": ">=20.9"
  },
  "overrides": {
    "postcss": "8.5.19"
  },
  "scripts": {
    "dev": "next dev",
    "start": "node scripts/start.mjs",
    "build": "node node_modules/next/dist/bin/next build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "prettier": "prettier --check .",
    "format:check": "bun run prettier",
    "format": "prettier --write .",
    "check": "bun run format:check && bun run lint && bun run typecheck && bun run build",
    "test:unit": "bun test tests/unit",
    "test:e2e:setup": "bun run tests/e2e/create-fixture.mjs",
    "test:e2e": "bun run test:e2e:setup && playwright test",
    "ci": "bun run check && bun run test:unit && bun run test:e2e"
  },
  "dependencies": {
    "@tanstack/react-table": "^8.21.3",
    "clsx": "^2.1.1",
    "lucide-react": "^1.24.0",
    "next": "16.2.10",
    "next-themes": "^0.4.6",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.3.3",
    "@types/bun": "1.3.14",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "9.39.5",
    "eslint-config-next": "16.2.10",
    "postcss": "^8.5.10",
    "prettier": "^3.9.5",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4.3.3",
    "typescript": "5.9.3"
  }
}
